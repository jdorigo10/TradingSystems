    "inputs": [
        {
            "id": "feedHandlerTests",
            "type": "pickString",
            "description": "Which input file do you want to use?",
            "options": [
                "default.txt"
            ],
            "default": "default.txt"
        },
        {
            "id": "matchingEngineTests",
            "type": "pickString",
            "description": "Which input file do you want to use?",
            "options": [
                "default.txt",
