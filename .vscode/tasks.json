{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile MarketFeedHandler",
            "type": "shell",
            "command": "g++ MarketFeedHandler/FeedHandler.cpp -o MarketFeedHandler/handler.exe"
        },
        {
            "label": "Run MarketFeedHandler with inputs",
            "type": "shell",
            "command": "handler.exe < test_cases/${input:feedHandlerTests}",
            "options": {
                "cwd": "${workspaceFolder}\\MarketFeedHandler",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Compile MatchingEngine",
            "type": "shell",
            "command": "g++ MatchingEngine/MatchingEngine.cpp -o MatchingEngine/engine.exe"
        },
        {
            "label": "Run Engine with inputs",
            "type": "shell",
            "command": "engine.exe < test_cases/${input:matchingEngineTests}",
            "options": {
                "cwd": "${workspaceFolder}\\MatchingEngine",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
